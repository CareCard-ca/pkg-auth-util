{
  "name": "@carecard/auth-util",
  "version": "3.10.0",
  "repository": "https://github.com/CareCard-ca/pkg-auth-util.git",
  "description": "Auth utility functions",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "mocha --recursive",
    "test:types": "tsc --noEmit && mocha -r ts-node/register test/types.test.ts",
    "test:coverage": "tsc --noEmit && nyc mocha --recursive -r ts-node/register 'test/**/*.{js,ts}'",
    "test:All": "npm run test && npm run test:types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint:fix": "eslint --fix",
    "lint": "eslint"
  },
  "keywords": [
    "auth",
    "utility",
    "cryptology",
    "jwt"
  ],
  "author": "CareCard team",
  "license": "ISC",
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "1.0.2",
    "@types/express": "5.0.6",
    "@types/mocha": "10.0.10",
    "@types/node": "25.9.3",
    "eslint": "9.39.4",
    "express": "5.2.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "prettier": "3.8.4",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@carecard/common-util": "3.10.0",
    "@carecard/validate": "3.10.0"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5",
    "js-yaml": "4.2.0"
  }
}
