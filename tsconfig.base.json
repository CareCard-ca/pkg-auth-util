{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "ES2021", "dom"],
    "declaration": true,
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
